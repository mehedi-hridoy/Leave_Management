<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- Leave Request: Tree View                                            -->
    <!-- ================================================================== -->
    <record id="view_leave_request_tree" model="ir.ui.view">
        <field name="name">leave.request.tree</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <tree string="Leave Requests"
                  decoration-danger="state == 'rejected'"
                  decoration-success="state == 'approved'"
                  decoration-info="state == 'submitted'"
                  decoration-muted="state == 'draft'"
                  multi_edit="1">
                <field name="name" decoration-bf="1"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="department_id" optional="show"/>
                <field name="leave_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="number_of_days" sum="Total Days"/>
                <field name="approver_id" widget="many2one_avatar_employee"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'submitted'"
                       decoration-danger="state == 'rejected'"
                       decoration-info="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Form View                                            -->
    <!-- ================================================================== -->
    <record id="view_leave_request_form" model="ir.ui.view">
        <field name="name">leave.request.form</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <form string="Leave Request">

                <!-- Header: Workflow buttons + Status bar -->
                <header>
                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            class="oe_highlight"
                            invisible="state != 'draft'"
                            data-hotkey="q"/>
                    <button name="action_approve"
                            type="object"
                            string="Approve"
                            class="oe_highlight"
                            invisible="state != 'submitted'"
                            groups="leave_request.group_leave_manager"
                            data-hotkey="w"/>
                    <button name="action_reject"
                            type="object"
                            string="Reject"
                            invisible="state != 'submitted'"
                            groups="leave_request.group_leave_manager"
                            data-hotkey="x"
                            confirm="Are you sure you want to reject this leave request?"/>
                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reset to Draft"
                            invisible="state != 'rejected'"
                            data-hotkey="z"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>

                <!-- Sheet: Main content area -->
                <sheet>
                    <!-- Ribbon for rejected requests -->
                    <widget name="web_ribbon" title="Rejected"
                            bg_color="text-bg-danger"
                            invisible="state != 'rejected'"/>

                    <!-- Title area with reference number -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Main information groups -->
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"
                                   widget="many2one_avatar_employee"
                                   readonly="state != 'draft'"/>
                            <field name="department_id"/>
                            <field name="approver_id"
                                   widget="many2one_avatar_employee"
                                   readonly="state not in ('draft',)"/>
                        </group>
                        <group string="Leave Details">
                            <field name="leave_type_id"
                                   readonly="state != 'draft'"/>
                            <field name="date_from"
                                   readonly="state != 'draft'"/>
                            <field name="date_to"
                                   readonly="state != 'draft'"/>
                            <field name="number_of_days"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <!-- Reason section -->
                    <notebook>
                        <page string="Description" name="description">
                            <field name="reason"
                                   readonly="state != 'draft'"
                                   placeholder="Enter the reason for your leave request..."/>
                        </page>
                    </notebook>
                </sheet>

                <!-- Chatter: Messages, followers, activities -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Search View                                          -->
    <!-- ================================================================== -->
    <record id="view_leave_request_search" model="ir.ui.view">
        <field name="name">leave.request.search</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <search string="Search Leave Requests">
                <!-- Search fields -->
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="leave_type_id"/>
                <field name="approver_id"/>

                <!-- Quick filters -->
                <separator/>
                <filter string="My Requests"
                        name="my_requests"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="My Team"
                        name="my_team"
                        domain="[('employee_id.parent_id.user_id', '=', uid)]"/>
                <filter string="To Approve"
                        name="to_approve"
                        domain="[('approver_id.user_id', '=', uid), ('state', '=', 'submitted')]"/>
                <separator/>
                <filter string="Draft"
                        name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted"
                        name="filter_submitted"
                        domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved"
                        name="filter_approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected"
                        name="filter_rejected"
                        domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Active Requests"
                        name="filter_active"
                        domain="[('state', 'in', ('draft', 'submitted'))]"/>

                <!-- Group By -->
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Employee"
                            name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Department"
                            name="group_department"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Leave Type"
                            name="group_leave_type"
                            context="{'group_by': 'leave_type_id'}"/>
                    <filter string="Approver"
                            name="group_approver"
                            context="{'group_by': 'approver_id'}"/>
                    <filter string="Status"
                            name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Start Date"
                            name="group_date_from"
                            context="{'group_by': 'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Kanban View                                          -->
    <!-- ================================================================== -->
    <record id="view_leave_request_kanban" model="ir.ui.view">
        <field name="name">leave.request.kanban</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state"
                    quick_create="false"
                    class="o_kanban_small_column">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="leave_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="number_of_days"/>
                <field name="state"/>
                <field name="approver_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb-1">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="state"
                                           widget="label_selection"
                                           options="{'classes': {
                                               'draft': 'info',
                                               'submitted': 'warning',
                                               'approved': 'success',
                                               'rejected': 'danger'
                                           }}"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="d-flex align-items-center mb-1">
                                        <field name="employee_id"
                                               widget="many2one_avatar_employee"/>
                                    </div>
                                    <div>
                                        <strong><field name="leave_type_id"/></strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-1">
                                    <div class="oe_kanban_bottom_left text-muted">
                                        <field name="date_from"/> — <field name="date_to"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <strong>
                                            <field name="number_of_days"/> day(s)
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Calendar View                                        -->
    <!-- ================================================================== -->
    <record id="view_leave_request_calendar" model="ir.ui.view">
        <field name="name">leave.request.calendar</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <calendar string="Leave Calendar"
                      date_start="date_from"
                      date_stop="date_to"
                      color="leave_type_id"
                      quick_create="0"
                      event_open_popup="1">
                <field name="employee_id" avatar_field="image_128"/>
                <field name="leave_type_id"/>
                <field name="number_of_days"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Pivot View (Leave Analysis)                          -->
    <!-- ================================================================== -->
    <record id="view_leave_request_pivot" model="ir.ui.view">
        <field name="name">leave.request.pivot</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <pivot string="Leave Analysis" sample="1">
                <field name="employee_id" type="row"/>
                <field name="leave_type_id" type="col"/>
                <field name="number_of_days" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Graph View                                           -->
    <!-- ================================================================== -->
    <record id="view_leave_request_graph" model="ir.ui.view">
        <field name="name">leave.request.graph</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <graph string="Leave Analysis" type="bar" sample="1">
                <field name="department_id"/>
                <field name="number_of_days" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Window Actions                                                      -->
    <!-- ================================================================== -->

    <!-- My Leave Requests (Employee view) -->
    <record id="action_leave_request" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">tree,kanban,form,calendar</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first leave request
            </p>
            <p>
                Submit your leave request and track its approval status.
            </p>
        </field>
    </record>

    <!-- Requests to Approve (Manager view) -->
    <record id="action_leave_request_to_approve" model="ir.actions.act_window">
        <field name="name">Requests to Approve</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="context">{
            'search_default_to_approve': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leave requests to approve
            </p>
            <p>
                All pending leave requests assigned to you will appear here.
            </p>
        </field>
    </record>

    <!-- All Requests (Admin view) -->
    <record id="action_leave_request_all" model="ir.actions.act_window">
        <field name="name">All Leave Requests</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">tree,kanban,form,calendar,pivot,graph</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leave requests found
            </p>
        </field>
    </record>

    <!-- Leave Analysis Dashboard -->
    <record id="action_leave_analysis" model="ir.actions.act_window">
        <field name="name">Leave Analysis</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="context">{'search_default_filter_approved': 1}</field>
    </record>

</odoo>