<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- Leave Request: Tree View                                            -->
    <!-- ================================================================== -->
    <record id="view_leave_request_tree" model="ir.ui.view">
        <field name="name">leave.request.tree</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <tree string="Leave Requests"
                  decoration-danger="state == 'refused'"
                  decoration-success="state == 'approved'"
                  decoration-info="state == 'confirmed'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="leave_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="number_of_days"/>
                <field name="state"
                       widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-warning="state == 'confirmed'"
                       decoration-danger="state == 'refused'"
                       decoration-info="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Form View                                            -->
    <!-- ================================================================== -->
    <record id="view_leave_request_form" model="ir.ui.view">
        <field name="name">leave.request.form</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <form string="Leave Request">

                <!-- ====================================================== -->
                <!-- Header: Workflow buttons + Status bar                   -->
                <!-- ====================================================== -->
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Submit"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            type="object"
                            string="Approve"
                            class="oe_highlight"
                            invisible="state != 'confirmed'"
                            groups="leave_request.group_leave_manager"/>
                    <button name="action_refuse"
                            type="object"
                            string="Refuse"
                            invisible="state != 'confirmed'"
                            groups="leave_request.group_leave_manager"/>
                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reset to Draft"
                            invisible="state != 'refused'"/>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,approved"/>
                </header>

                <!-- ====================================================== -->
                <!-- Sheet: Main content area                                -->
                <!-- ====================================================== -->
                <sheet>
                    <!-- Title area with reference number -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Main information groups -->
                    <group>
                        <group string="Employee Information">
                            <field name="employee_id"
                                   readonly="state != 'draft'"/>
                            <field name="department_id"/>
                            <field name="manager_id"/>
                        </group>
                        <group string="Leave Details">
                            <field name="leave_type_id"
                                   readonly="state != 'draft'"/>
                            <field name="date_from"
                                   readonly="state != 'draft'"/>
                            <field name="date_to"
                                   readonly="state != 'draft'"/>
                            <field name="number_of_days"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <!-- Reason section in a notebook page -->
                    <notebook>
                        <page string="Description" name="description">
                            <field name="reason"
                                   readonly="state != 'draft'"
                                   placeholder="Enter the reason for your leave request..."/>
                        </page>
                    </notebook>
                </sheet>

                <!-- ====================================================== -->
                <!-- Chatter: Messages, followers, activities               -->
                <!-- ====================================================== -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Search View                                          -->
    <!-- ================================================================== -->
    <record id="view_leave_request_search" model="ir.ui.view">
        <field name="name">leave.request.search</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <search string="Search Leave Requests">
                <!-- Search fields -->
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="leave_type_id"/>

                <!-- Quick filters -->
                <separator/>
                <filter string="My Requests"
                        name="my_requests"
                        domain="[('employee_id.user_id', '=', uid)]"/>
                <filter string="My Team"
                        name="my_team"
                        domain="[('manager_id.user_id', '=', uid)]"/>
                <separator/>
                <filter string="Draft"
                        name="filter_draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="To Approve"
                        name="filter_confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Approved"
                        name="filter_approved"
                        domain="[('state', '=', 'approved')]"/>
                <filter string="Refused"
                        name="filter_refused"
                        domain="[('state', '=', 'refused')]"/>

                <!-- Group By -->
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Employee"
                            name="group_employee"
                            context="{'group_by': 'employee_id'}"/>
                    <filter string="Department"
                            name="group_department"
                            context="{'group_by': 'department_id'}"/>
                    <filter string="Leave Type"
                            name="group_leave_type"
                            context="{'group_by': 'leave_type_id'}"/>
                    <filter string="Status"
                            name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Start Date"
                            name="group_date_from"
                            context="{'group_by': 'date_from:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Kanban View                                          -->
    <!-- ================================================================== -->
    <record id="view_leave_request_kanban" model="ir.ui.view">
        <field name="name">leave.request.kanban</field>
        <field name="model">leave.request</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile"
                    default_group_by="state"
                    quick_create="false">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="leave_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="number_of_days"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="state"
                                           widget="label_selection"
                                           options="{'classes': {
                                               'draft': 'info',
                                               'confirmed': 'warning',
                                               'approved': 'success',
                                               'refused': 'danger'
                                           }}"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="employee_id"/>
                                    <br/>
                                    <field name="leave_type_id"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <span>
                                            <field name="date_from"/> -
                                            <field name="date_to"/>
                                        </span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <strong>
                                            <field name="number_of_days"/> day(s)
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Request: Window Action                                        -->
    <!-- ================================================================== -->
    <record id="action_leave_request" model="ir.actions.act_window">
        <field name="name">Leave Requests</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="context">{'search_default_my_requests': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first leave request
            </p>
            <p>
                Submit your leave request and track its approval status.
            </p>
        </field>
    </record>

    <!--
        Action for Managers: Opens with "To Approve" filter active
        so managers immediately see pending requests.
    -->
    <record id="action_leave_request_to_approve" model="ir.actions.act_window">
        <field name="name">Requests to Approve</field>
        <field name="res_model">leave.request</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_leave_request_search"/>
        <field name="context">{
            'search_default_my_team': 1,
            'search_default_filter_confirmed': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No leave requests to approve
            </p>
            <p>
                All pending leave requests from your team will appear here.
            </p>
        </field>
    </record>

</odoo>