<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!--
        Menu Architecture
        ==================
        ┌─ Leave Management (root app)
        │  ├─ Leave Requests
        │  │  ├─ My Requests
        │  │  ├─ Requests to Approve (managers)
        │  │  └─ All Requests (admins)
        │  ├─ Reporting
        │  │  └─ Leave Analysis (admins)
        │  └─ Configuration
        │     └─ Leave Types (admins)
    -->

    <!-- Root Menu -->
    <menuitem id="menu_leave_root"
              name="Leave Management"
              sequence="90"/>

    <!-- Leave Requests Section -->
    <menuitem id="menu_leave_requests"
              name="Leave Requests"
              parent="menu_leave_root"
              sequence="10"/>

    <menuitem id="menu_leave_request_my"
              name="My Requests"
              parent="menu_leave_requests"
              action="action_leave_request"
              sequence="10"/>

    <menuitem id="menu_leave_request_to_approve"
              name="Requests to Approve"
              parent="menu_leave_requests"
              action="action_leave_request_to_approve"
              groups="group_leave_manager"
              sequence="20"/>

    <menuitem id="menu_leave_request_all"
              name="All Requests"
              parent="menu_leave_requests"
              action="action_leave_request_all"
              groups="group_leave_admin"
              sequence="30"/>

    <!-- Reporting Section -->
    <menuitem id="menu_leave_reporting"
              name="Reporting"
              parent="menu_leave_root"
              groups="group_leave_manager"
              sequence="50"/>

    <menuitem id="menu_leave_analysis"
              name="Leave Analysis"
              parent="menu_leave_reporting"
              action="action_leave_analysis"
              sequence="10"/>

    <!-- Configuration Section -->
    <menuitem id="menu_leave_configuration"
              name="Configuration"
              parent="menu_leave_root"
              groups="group_leave_admin"
              sequence="90"/>

    <menuitem id="menu_leave_type"
              name="Leave Types"
              parent="menu_leave_configuration"
              action="action_leave_type"
              sequence="10"/>

</odoo>
