<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ================================================================== -->
    <!-- Leave Type: Tree View                                               -->
    <!-- ================================================================== -->
    <record id="view_leave_type_tree" model="ir.ui.view">
        <field name="name">leave.type.tree</field>
        <field name="model">leave.type</field>
        <field name="arch" type="xml">
            <tree string="Leave Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="max_days"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Type: Form View                                               -->
    <!-- ================================================================== -->
    <record id="view_leave_type_form" model="ir.ui.view">
        <field name="name">leave.type.form</field>
        <field name="model">leave.type</field>
        <field name="arch" type="xml">
            <form string="Leave Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g., Casual Leave"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="code"/>
                            <field name="max_days"/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group string="Settings">
                            <field name="active"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================== -->
    <!-- Leave Type: Action                                                  -->
    <!-- ================================================================== -->
    <record id="action_leave_type" model="ir.actions.act_window">
        <field name="name">Leave Types</field>
        <field name="res_model">leave.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first leave type
            </p>
            <p>
                Define the types of leaves available in your organization
                (e.g., Casual Leave, Sick Leave, Annual Leave).
            </p>
        </field>
    </record>

</odoo>
