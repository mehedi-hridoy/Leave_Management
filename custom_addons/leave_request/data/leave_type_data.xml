<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Default Leave Types
            ====================
            Pre-populated leave types for immediate use.
            noupdate="1" ensures users can modify these without
            their changes being reverted on module upgrade.
        -->
        <record id="leave_type_casual" model="leave.type">
            <field name="name">Casual Leave</field>
            <field name="code">CL</field>
            <field name="max_days">12</field>
            <field name="sequence">10</field>
            <field name="color">2</field>
        </record>

        <record id="leave_type_sick" model="leave.type">
            <field name="name">Sick Leave</field>
            <field name="code">SL</field>
            <field name="max_days">14</field>
            <field name="sequence">20</field>
            <field name="color">4</field>
        </record>

        <record id="leave_type_annual" model="leave.type">
            <field name="name">Annual Leave</field>
            <field name="code">AL</field>
            <field name="max_days">21</field>
            <field name="sequence">30</field>
            <field name="color">10</field>
        </record>

        <record id="leave_type_unpaid" model="leave.type">
            <field name="name">Unpaid Leave</field>
            <field name="code">UL</field>
            <field name="max_days">0</field>
            <field name="sequence">40</field>
            <field name="color">1</field>
        </record>

    </data>
</odoo>
