<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Sequence for Leave Request auto-numbering
            ==========================================
            Generates references like: LR/2026/0001, LR/2026/0002, ...

            noupdate="1" means this record will NOT be overwritten
            on module upgrade. This is critical for sequences because
            the counter (number_next) must be preserved.
        -->
        <record id="sequence_leave_request" model="ir.sequence">
            <field name="name">Leave Request</field>
            <field name="code">leave.request</field>
            <field name="prefix">LR/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
